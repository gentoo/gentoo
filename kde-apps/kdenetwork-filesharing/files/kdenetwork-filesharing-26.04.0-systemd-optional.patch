 samba/filepropertiesplugin/sambausershareplugin.h | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/samba/filepropertiesplugin/sambausershareplugin.h b/samba/filepropertiesplugin/sambausershareplugin.h
