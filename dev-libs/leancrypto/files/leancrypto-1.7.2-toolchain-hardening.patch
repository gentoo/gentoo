+add_global_arguments([ '-fwrapv',
 		       '-fvisibility=hidden',
 		       '-Wconversion',
 		       '-Wcast-align',
@@ -57,36 +55,14 @@ if cc.has_argument('-Wdocumentation')
 			     language: 'c')
