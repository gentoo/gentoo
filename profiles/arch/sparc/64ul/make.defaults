MULTILIB_ABIS="sparc64"
DEFAULT_ABI="sparc64"
ABI="${DEFAULT_ABI}"

CHOST="sparc64-unknown-linux-gnu"

# James Le Cuirot <chewi@gentoo.org> (2026-02-13)
# Enable the native QEMU target for this architecture by default.
QEMU_SOFTMMU_TARGETS="sparc64"
