CHOST="sparc-unknown-linux-gnu"

# Multilib stuff
MULTILIB_ABIS="sparc32"
DEFAULT_ABI="sparc32"
ABI="${DEFAULT_ABI}"

# James Le Cuirot <chewi@gentoo.org> (2026-02-13)
# Enable the native QEMU target for this architecture by default.
QEMU_SOFTMMU_TARGETS="sparc"
