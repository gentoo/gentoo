-
-_virt_edit ()
-{
-    _guestfs_virttools "virt-edit" 0
-} &&
-complete -o default -F _virt_edit virt-edit
-
-_virt_filesystems ()
-{
-    _guestfs_virttools "virt-filesystems" 1
-} &&
-complete -o default -F _virt_filesystems virt-filesystems
-
-_virt_format ()
-{
-    _guestfs_virttools "virt-format" 0
-} &&
