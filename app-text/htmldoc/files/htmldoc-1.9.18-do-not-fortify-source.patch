From: Filip Kobierski <fkobi@pm.me>
Date: Tue, 3 Sep 2024 15:19:21 +0200
Subject: [PATCH] do not fortify source

Signed-off-by: Filip Kobierski <fkobi@pm.me>
---
 configure.ac | 2 --
 1 file changed, 2 deletions(-)

diff --git a/configure.ac b/configure.ac
index e5bed4f..498616f 100644
--- a/configure.ac
+++ b/configure.ac
@@ -296,8 +296,6 @@ AS_IF([test -n "$GXX"], [
     ], [
 	# Otherwise use the Fortify enhancements to catch any unbounded
 	# string operations...
-	CFLAGS="$CFLAGS -D_FORTIFY_SOURCE=3"
-	CXXFLAGS="$CXXFLAGS -D_FORTIFY_SOURCE=3"
     ])
 
     dnl Set optimization flags...
-- 
2.44.2

